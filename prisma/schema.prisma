generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is managed via prisma.config.ts (Prisma 7+)
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  TEACHER
  STUDENT
  STAFF
  ACCOUNTANT
  CASE_WORKER
  LIBRARIAN
}

enum BookLoanStatus {
  BORROWED
  RETURNED
  OVERDUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ExamType {
  QUIZ
  MIDTERM
  FINAL
  MOCK
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  MCQ
  WRITTEN
  GED_RLA_PASSAGE
  GED_MATH
  GED_SCIENCE
  GED_SOCIAL_STUDIES
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
  WAIVED
}

// ── Phase 2 advanced exam enums ──────────────────────────────────────────────
enum StimulusType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  TABLE
  CHART
  DOCUMENT
}

enum AttemptState {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  SUBMITTED
  AUTO_SUBMITTED
  PENDING_GRADING
  FINALIZED
  RELEASED
  INVALIDATED
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  RESOLVED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  URGENT
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  firstName     String
  lastName      String
  profilePhotoUrl String?
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  mustChangePassword Boolean @default(false)

  // Relations
  studentProfile Student?
  teacherProfile Teacher?
  recordedAttendances Attendance[] @relation("RecordedBy")
  caseNotes      CaseNote[]
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages MessageRecipient[] @relation("ReceivedMessages")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

model SchoolProfile {
  id              String   @id @default(uuid())
  name            String
  address         String?
  contactEmail    String?
  contactPhone    String?
  establishedYear Int?

  // Branding
  logoUrl           String?
  signatureUrl      String?
  loginHeroUrl      String?
  primaryColor      String?  @default("#5865f2")
  accentColor       String?  @default("#3b82f6")
  darkModeDefault   Boolean  @default(false)
  reportHeaderStyle String?  @default("standard")

  // System / localization
  timezone          String?  @default("Asia/Bangkok")
  dateFormat        String?  @default("DD/MM/YYYY")
  currency          String?  @default("THB")
  defaultLanguage   String?  @default("en")
  fileUploadLimitMb Int      @default(10)
  backupEnabled     Boolean  @default(true)
  lockdownBrowserEnabled Boolean @default(true)
  lockdownRequireFullscreen Boolean @default(true)
  lockdownBlockClipboard Boolean @default(true)
  lockdownBlockContextMenu Boolean @default(true)
  lockdownBlockShortcuts Boolean @default(true)
  lockdownAutoSubmitOnViolation Boolean @default(true)
  lockdownMaxWarnings Int @default(3)
  lockdownInstructions String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Student {
  id             String   @id @default(uuid())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  studentCode    String   @unique
  preferredName  String?
  dateOfBirth    DateTime?
  enrollmentDate DateTime @default(now())
  guardianName   String?
  guardianRelationship String?
  guardianPhone  String?
  guardianEmail  String?
  contactNumber  String?
  country        String?
  identityType   String?
  identityNumber String?
  legalDocumentationStatus String?
  address        String?
  emergencyContact String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelationship String?
  previousSchool String?
  previousEducationLevel String?
  educationLevel String?
  medicalInformation String?
  allergies      String?
  notes          String?
  gender         String?
  profilePhotoUrl String?
  status         String?  @default("ACTIVE")
  
  classId        String?
  class          Class?   @relation(fields: [classId], references: [id])
  
  attendances    Attendance[]
  examAttempts   ExamAttempt[]
  feePayments    FeePayment[]
  caseRecords    CaseRecord[]
  grades         Grade[]
  gedReadiness   GedReadiness[]
  documents      GeneratedDocument[]
  examAssignments    ExamAssignment[]
  examAccommodations ExamAccommodation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([studentCode])
  @@index([classId])
}

model Teacher {
  id             String   @id @default(uuid())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  teacherCode    String   @unique
  hireDate       DateTime @default(now())
  specialization String?
  profilePhotoUrl String?

  classes        ClassTeacher[]
  subjects       SubjectTeacher[]
  lessonPlans    LessonPlan[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([teacherCode])
}

model Class {
  id             String   @id @default(uuid())
  name           String
  level          String   // e.g., "GED", "Pre-GED"
  academicYear   String
  room           String?
  capacity       Int?
  
  students       Student[]
  teachers       ClassTeacher[]
  exams          Exam[]
  attendances    Attendance[]
  gradeItems     GradeItem[]
  categoryWeights CategoryWeight[]
  lessonPlans    LessonPlan[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Intermediary table for Teacher <-> Class (Many-to-Many)
model ClassTeacher {
  classId        String
  class          Class    @relation(fields: [classId], references: [id])
  teacherId      String
  teacher        Teacher  @relation(fields: [teacherId], references: [id])
  
  @@id([classId, teacherId])
  @@index([teacherId])
  @@index([classId])
}

model Subject {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  description    String?
  level          String   @default("GED")
  status         String   @default("ACTIVE")

  teachers       SubjectTeacher[]
  exams          Exam[]
  gradeItems     GradeItem[]
  lessonPlans    LessonPlan[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Intermediary table for Teacher <-> Subject
model SubjectTeacher {
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id])
  teacherId      String
  teacher        Teacher  @relation(fields: [teacherId], references: [id])
  
  @@id([subjectId, teacherId])
  @@index([teacherId])
  @@index([subjectId])
}

model Attendance {
  id             String   @id @default(uuid())
  date           DateTime
  status         AttendanceStatus
  remarks        String?
  
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  classId        String
  class          Class    @relation(fields: [classId], references: [id])
  recordedById   String
  recordedBy     User     @relation("RecordedBy", fields: [recordedById], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@index([date])
}

model Exam {
  id             String   @id @default(uuid())
  title          String
  type           ExamType
  status         String   @default("PUBLISHED") // DRAFT | SCHEDULED | ACTIVE | CLOSED | ARCHIVED | PUBLISHED
  date           DateTime
  durationMinutes Int?
  totalMarks     Float?
  settings       Json?

  // Phase 2 scheduling
  availableFrom        DateTime?
  availableUntil       DateTime?
  resultReleaseAt      DateTime?
  attemptLimit         Int      @default(1)
  gracePeriodMinutes   Int      @default(0)
  allowLateStart       Boolean  @default(true)
  requiresAccessCode   Boolean  @default(false)
  accessCodeHash       String?
  requiresInvigilator  Boolean  @default(false)

  // Phase 2 delivery / scoring options
  shuffleQuestions     Boolean  @default(false)
  shuffleOptions       Boolean  @default(false)
  negativeMarking      Boolean  @default(false)
  passMark             Float?

  classId        String
  class          Class    @relation(fields: [classId], references: [id])
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id])

  questions      Question[]
  attempts       ExamAttempt[]

  // Phase 2 relations
  sections       ExamSection[]
  stimuli        Stimulus[]
  questionGroups QuestionGroup[]
  assignments    ExamAssignment[]
  accommodations ExamAccommodation[]
  rubrics        GradingRubric[]
  resultPolicy   ExamResultPolicy?
  questionStats  QuestionStatistic[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([status])
  @@index([availableFrom])
  @@index([availableUntil])
}

model Question {
  id             String   @id @default(uuid())
  text           String
  type           QuestionType
  points         Float
  options        Json?    // Optional for multiple choice
  correctAnswer  String?  // Can be an option string or detailed answer
  explanation    String?  // Shown only after result release

  // Phase 2: structure
  orderIndex     Int      @default(0)
  sectionId      String?
  section        ExamSection?   @relation(fields: [sectionId], references: [id])
  groupId        String?
  group          QuestionGroup? @relation(fields: [groupId], references: [id])
  stimulusId     String?
  stimulus       Stimulus?      @relation(fields: [stimulusId], references: [id])

  // Phase 2: partial-credit / scoring config
  correctAnswers   Json?    // multiple accepted text answers
  optionWeights    Json?    // per-option weighting for multi-select partial scoring
  negativePoints   Float?   // negative marking magnitude (positive number)
  minScore         Float?   // minimum score floor for this question
  numericTolerance Float?   // tolerance for numeric answers
  caseSensitive    Boolean  @default(false)
  partialCredit    Boolean  @default(false)
  requiresManualGrading Boolean @default(false)

  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  answers        ExamAnswer[]
  rubrics        GradingRubric[]
  manualGrades   ManualGrade[]
  statistic      QuestionStatistic?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
  @@index([sectionId])
  @@index([groupId])
  @@index([stimulusId])
}

model ExamAttempt {
  id             String   @id @default(uuid())
  score          Float?
  isCompleted    Boolean  @default(false)
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  securityWarnings Int     @default(0)
  autoSubmitted   Boolean @default(false)
  integrityEvents Json?

  // Phase 2: lifecycle state machine
  state          AttemptState @default(NOT_STARTED)
  attemptNumber  Int      @default(1)

  // Phase 2: server-authoritative timing
  serverDeadline DateTime?       // absolute time the attempt must end (authoritative)
  effectiveDurationMinutes Int?  // base duration + accommodation extra time
  pausedAt       DateTime?
  accumulatedPauseSeconds Int @default(0)
  lastSavedAt    DateTime?
  submittedAt    DateTime?
  gradedAt       DateTime?
  releasedAt     DateTime?
  invalidatedAt  DateTime?
  gradingStatus  String?         // PENDING | IN_REVIEW | COMPLETE

  // Phase 2: single-session + integrity
  sessionToken   String?         // active session; mismatched tokens are rejected
  questionOrder  Json?           // frozen randomized order for this attempt
  ipAddress      String?
  userAgent      String?
  deviceInfo     Json?

  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id])
  assignmentId   String?
  assignment     ExamAssignment? @relation(fields: [assignmentId], references: [id])
  accommodationId String?
  accommodation  ExamAccommodation? @relation(fields: [accommodationId], references: [id])

  answers        ExamAnswer[]
  events         AttemptEvent[]
  snapshots      AttemptSnapshot[]
  manualGrades   ManualGrade[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, examId, attemptNumber])
  @@index([studentId])
  @@index([examId])
  @@index([state])
  @@index([assignmentId])
}

model ExamAnswer {
  id             String   @id @default(uuid())
  answerText     String?
  selectedOptions Json?   // for multi-select questions
  isCorrect      Boolean?
  pointsAwarded  Float?   // final awarded points (auto + manual)
  autoScore      Float?   // machine-scored component
  manualScore    Float?   // grader-assigned component
  maxPoints      Float?
  flaggedForReview Boolean @default(false) // student self-flag
  timeSpentSeconds Int?
  gradingState   String?  // NOT_REQUIRED | PENDING | GRADED

  attemptId      String
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question    @relation(fields: [questionId], references: [id])

  manualGrades   ManualGrade[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model LibraryResource {
  id             String   @id @default(uuid())
  title          String
  author         String?
  isbn           String?
  type           String   // e.g., "BOOK", "DIGITAL", "EQUIPMENT"
  totalCopies    Int      @default(1)
  availableCopies Int     @default(1)
  description    String?
  visibility     String?  @default("ALL")
  classId        String?
  subjectId      String?
  externalUrl    String?

  // Enhanced metadata
  fileSize        Int?
  mimeType        String?
  downloadCount   Int      @default(0)
  lastDownloaded  DateTime?

  // Organization
  category        String?
  tags            String[]
  subjectAreas    String[]
  gradeLevels     String[]

  // Audit
  uploadedById    String?
  uploadedByName  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FeePayment {
  id             String   @id @default(uuid())
  amount         Float
  currency       String   @default("MYR")
  dueDate        DateTime
  paidDate       DateTime?
  status         FeeStatus @default(PENDING)
  description    String?
  receiptNumber  String?   @unique
  paymentMethod  String?
  notes          String?
  
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model CaseRecord {
  id             String   @id @default(uuid())
  title          String
  description    String
  status         CaseStatus @default(OPEN)
  priority       CasePriority @default(MEDIUM)
  category       String?  // e.g., "ACADEMIC", "DISCIPLINE", "WELFARE"
  
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  
  notes          CaseNote[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model CaseNote {
  id             String   @id @default(uuid())
  content        String
  
  caseRecordId   String
  caseRecord     CaseRecord @relation(fields: [caseRecordId], references: [id], onDelete: Cascade)
  
  createdById    String
  createdBy      User       @relation(fields: [createdById], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([caseRecordId])
  @@index([createdById])
}

model VideoLesson {
  id            String   @id @default(uuid())
  title         String
  description   String?
  videoUrl      String
  thumbnailUrl  String?
  duration      Int?     // seconds
  classId       String?
  subjectId     String?
  visibility    String   @default("ALL") // ALL | STUDENTS | TEACHERS_ONLY
  status        String   @default("PUBLISHED") // PUBLISHED | DRAFT | ARCHIVED
  uploadedById  String
  uploadedByName String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progressRecords VideoProgress[]

  @@index([classId])
  @@index([subjectId])
  @@index([uploadedById])
}

model VideoProgress {
  id            String   @id @default(uuid())
  userId        String
  videoId       String
  video         VideoLesson @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // Position in seconds where the user stopped watching
  currentPosition   Int      @default(0)
  // Whether the user has completed the video (watched 90%+)
  isCompleted       Boolean  @default(false)
  // Last time this progress was updated
  lastWatchedAt     DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  userName    String?
  action      String
  entityType  String
  entityId    String?
  description String
  ipAddress   String?
  userAgent   String?
  severity    String   @default("INFO")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
}

// -----------------------------------------------------------------------------
// PHYSICAL LIBRARY (book catalog + borrowing)
// -----------------------------------------------------------------------------

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String?
  isbn            String?
  publisher       String?
  publishedYear   Int?
  category        String?  // e.g. Fiction, Science, Reference
  language        String?
  edition         String?
  shelfLocation   String?  // e.g. "A-12", "Reference Shelf 3"
  description     String?
  coverUrl        String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)

  loans           BookLoan[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([title])
  @@index([author])
  @@index([category])
  @@index([isbn])
}

model BookLoan {
  id             String         @id @default(uuid())
  bookId         String
  book           Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)

  // Borrower is stored denormalized (matches AuditLog / VideoLesson pattern) so
  // loans can be issued to students, staff, or external members alike.
  studentId      String?
  borrowerName   String
  borrowerType   String?        // e.g. STUDENT, TEACHER, STAFF, OTHER

  status         BookLoanStatus @default(BORROWED)
  borrowedDate   DateTime       @default(now())
  dueDate        DateTime
  returnedDate   DateTime?

  recordedById   String?
  recordedByName String?
  notes          String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([bookId])
  @@index([studentId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// SCHOOL OPERATIONS
// -----------------------------------------------------------------------------

model AdmissionApplication {
  id              String   @id @default(uuid())
  applicationNo   String?  @unique
  applicantName   String
  preferredName   String?
  email           String?
  dateOfBirth     DateTime?
  gender          String?
  country         String?
  address         String?
  contactNumber   String?

  targetLevel     String?
  targetClassId   String?
  previousSchool  String?
  previousEducationLevel String?
  previousEducationNotes String?

  guardianName    String?
  guardianRelationship String?
  guardianPhone   String?
  guardianEmail   String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelationship String?

  identityType    String?
  identityNumber  String?
  legalDocumentationStatus String? @default("PENDING") // PENDING | VERIFIED | MISSING | EXPIRED
  boardingType    String?  @default("DAY") // DAY | BOARDING
  medicalInformation String?
  allergies       String?
  medicationNotes String?

  interviewAt     DateTime?
  interviewMode   String?
  interviewLocation String?
  interviewNotes  String?
  decisionAt      DateTime?
  decisionById    String?
  decisionByName  String?
  decisionNotes   String?
  status          String   @default("SUBMITTED") // SUBMITTED | DOCUMENTS_PENDING | INTERVIEW_SCHEDULED | UNDER_REVIEW | APPROVED | WAITLISTED | REJECTED | ENROLLED | WITHDRAWN
  priority        String?  @default("NORMAL") // LOW | NORMAL | HIGH
  notes           String?

  convertedStudentId String?
  convertedUserId String?
  convertedAt     DateTime?
  submittedAt     DateTime @default(now())
  createdById      String?
  createdByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents       AdmissionDocument[]
  timeline        AdmissionTimelineEvent[]

  @@index([applicationNo])
  @@index([status])
  @@index([targetLevel])
  @@index([targetClassId])
  @@index([convertedStudentId])
}

model AdmissionDocument {
  id              String   @id @default(uuid())
  applicationId   String
  application     AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title           String
  documentType    String   @default("OTHER") // UNHCR | PASSPORT | BIRTH_CERTIFICATE | SCHOOL_RECORD | GUARDIAN_DOC | MEDICAL | PHOTO | OTHER
  checklistStatus String   @default("PENDING") // PENDING | RECEIVED | VERIFIED | REJECTED | NOT_REQUIRED
  fileUrl         String?
  fileName        String?
  fileSize        Int      @default(0)
  mimeType        String   @default("application/octet-stream")
  notes           String?
  uploadedById    String?
  uploadedByName  String?
  verifiedById    String?
  verifiedByName  String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([applicationId])
  @@index([documentType])
  @@index([checklistStatus])
}

model AdmissionTimelineEvent {
  id              String   @id @default(uuid())
  applicationId   String
  application     AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  eventType       String
  title           String
  description     String?
  fromStatus      String?
  toStatus        String?
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())

  @@index([applicationId])
  @@index([eventType])
}

model AcademicCalendarEvent {
  id          String   @id @default(uuid())
  title       String
  eventType   String   @default("SCHOOL") // SCHOOL | HOLIDAY | EXAM | MEETING | ACTIVITY
  startDate   DateTime
  endDate     DateTime?
  audience    String   @default("ALL") // ALL | STUDENTS | TEACHERS | STAFF
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([eventType])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  classId     String?
  subjectId   String?
  dueDate     DateTime?
  status      String   @default("OPEN") // OPEN | CLOSED | ARCHIVED
  createdById String?
  createdByName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([status])
}

model CertificateRecord {
  id          String   @id @default(uuid())
  studentId   String?
  studentName String
  certificateType String
  issueDate   DateTime @default(now())
  status      String   @default("ISSUED") // DRAFT | ISSUED | REVOKED
  referenceNo String?  @unique
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model CommunicationLog {
  id          String   @id @default(uuid())
  title       String
  channel     String   @default("PHONE") // PHONE | SMS | EMAIL | MEETING | HOME_VISIT | OTHER
  audience    String   @default("GUARDIAN") // GUARDIAN | STUDENT | TEACHER | STAFF | COMMUNITY
  contactName String?
  contactInfo String?
  message     String
  followUpDate DateTime?
  status      String   @default("LOGGED") // LOGGED | NEEDS_FOLLOW_UP | RESOLVED
  createdById String?
  createdByName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel])
  @@index([status])
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("GENERAL")
  quantity    Int      @default(1)
  condition   String   @default("GOOD") // NEW | GOOD | NEEDS_REPAIR | LOST | RETIRED
  location    String?
  assignedTo  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([condition])
}

// -----------------------------------------------------------------------------
// E-LIBRARY (online EPUB/PDF reading)
// -----------------------------------------------------------------------------

model Ebook {
  id              String   @id @default(uuid())
  title           String
  author          String?
  description     String?
  category        String?
  language        String?
  coverUrl        String?

  format          String   // "PDF" | "EPUB"
  fileName        String   // stored file name on disk (uuid + ext)
  originalName    String?  // original upload filename
  fileSize        Int?     // bytes

  visibility      String   @default("ALL")   // ALL | STUDENTS | TEACHERS_ONLY
  downloadAllowed Boolean  @default(false)   // false = read online only

  uploadedById    String?
  uploadedByName  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([title])
  @@index([author])
  @@index([category])
  @@index([format])
}

model Announcement {
  id             String    @id @default(uuid())
  title          String
  body           String
  audience       String    @default("ALL") // ALL | TEACHERS | STUDENTS | CLASS
  classId        String?
  className      String?
  pinned         Boolean   @default(false)
  expiresAt      DateTime?
  createdById    String?
  createdByName  String?
  status         String    @default("ACTIVE") // ACTIVE | ARCHIVED

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([audience])
  @@index([status])
  @@index([classId])
}

model TimetableEntry {
  id             String   @id @default(uuid())
  classId        String?
  className      String?
  subjectId      String?
  subjectName    String?
  subjectColor   String?  @default("bg-blue-500")
  teacherId      String?
  teacherName    String?
  substituteTeacherId String?
  substituteTeacherName String?
  academicYear   String?
  term           String?
  dayOfWeek      String
  startTime      String
  endTime        String
  room           String?
  scheduleType   String   @default("CLASS") // CLASS | HOLIDAY | SPECIAL_EVENT | EXAM | MEETING
  recurrence     String   @default("WEEKLY") // ONCE | WEEKLY | BIWEEKLY
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  status         String   @default("ACTIVE") // ACTIVE | CANCELLED | SUBSTITUTED
  cancellationReason String?
  eventDate      DateTime?
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([classId])
  @@index([teacherId])
  @@index([substituteTeacherId])
  @@index([dayOfWeek])
  @@index([academicYear])
  @@index([term])
  @@index([room])
  @@index([status])
  @@index([scheduleType])
}

model StudentDocument {
  id             String    @id @default(uuid())
  studentId      String
  title          String
  documentType   String    @default("OTHER") // UNHCR | PASSPORT | BIRTH_CERTIFICATE | SCHOOL_RECORD | GUARDIAN_DOC | MEDICAL | OTHER
  fileUrl        String
  fileName       String
  fileSize       Int       @default(0)
  mimeType       String    @default("application/octet-stream")
  expiryDate     DateTime?
  uploadedById   String?
  uploadedByName String?
  status         String    @default("ACTIVE") // ACTIVE | ARCHIVED

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([studentId])
  @@index([documentType])
  @@index([status])
}

// ── Gradebook & GED readiness ────────────────────────────────────────────────
enum GradeCategoryType {
  ASSIGNMENT
  QUIZ
  MIDTERM
  FINAL
  MOCK_GED
}

enum GedSubjectArea {
  RLA
  MATH
  SCIENCE
  SOCIAL_STUDIES
}

enum GedReadinessStatus {
  NOT_READY
  DEVELOPING
  NEAR_READY
  READY
  TEST_SCHEDULED
  PASSED
}

model GradeItem {
  id           String            @id @default(uuid())
  title        String
  category     GradeCategoryType
  maxMarks     Float             @default(100)
  date         DateTime          @default(now())

  classId      String
  class        Class             @relation(fields: [classId], references: [id])
  subjectId    String?
  subject      Subject?          @relation(fields: [subjectId], references: [id])

  createdById  String?
  grades       Grade[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([category])
}

model Grade {
  id           String     @id @default(uuid())
  gradeItemId  String
  gradeItem    GradeItem  @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  marks        Float?
  comment      String?
  gradedById   String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([gradeItemId, studentId])
  @@index([studentId])
}

model CategoryWeight {
  id         String            @id @default(uuid())
  classId    String
  class      Class             @relation(fields: [classId], references: [id])
  category   GradeCategoryType
  weight     Int               @default(0)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([classId, category])
  @@index([classId])
}

model GedReadiness {
  id           String              @id @default(uuid())
  studentId    String
  student      Student             @relation(fields: [studentId], references: [id])
  subject      GedSubjectArea
  status       GedReadinessStatus  @default(NOT_READY)
  note         String?
  updatedById  String?

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([studentId, subject])
  @@index([studentId])
}

// ── Official documents (report cards, transcripts, certificates) ─────────────
enum DocumentType {
  REPORT_CARD
  TRANSCRIPT
  ENROLLMENT_CONFIRMATION
  COMPLETION_CERTIFICATE
  PROGRESS_REPORT
}

enum DocumentStatus {
  ACTIVE
  CANCELLED
  REISSUED
}

model GeneratedDocument {
  id             String         @id @default(uuid())
  documentNumber String         @unique
  verifyToken    String         @unique
  type           DocumentType
  status         DocumentStatus @default(ACTIVE)

  studentId      String
  student        Student        @relation(fields: [studentId], references: [id])
  studentName    String
  studentCode    String
  className      String?
  term           String?

  payload        Json?
  issuedById     String?
  issuedByName   String?
  issueDate      DateTime       @default(now())

  reissuedFromId String?
  cancelledReason String?
  downloadCount  Int            @default(0)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([studentId])
  @@index([type])
  @@index([status])
}

// ── Messaging System ─────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(uuid())
  subject        String
  body           String
  sentAt         DateTime @default(now())

  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])

  recipients     MessageRecipient[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([senderId])
  @@index([sentAt])
}

model MessageRecipient {
  id             String   @id @default(uuid())
  messageId      String
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  recipientId    String
  recipient      User     @relation("ReceivedMessages", fields: [recipientId], references: [id])

  readAt         DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([messageId, recipientId])
  @@index([messageId])
  @@index([recipientId])
  @@index([readAt])
}

// ── Generated Reports Tracking ───────────────────────────────────────────────

model SavedReport {
  id              String   @id @default(uuid())
  name            String
  description     String?
  reportType      String   // "attendance" | "exams" | "students" | "fees"

  // Report configuration
  filters         Json     // Store query parameters (classId, month, etc.)

  // Audit
  generatedById   String
  generatedByName  String?

  // Generation tracking
  lastGeneratedAt DateTime?
  generationCount Int      @default(0)

  generations    ReportGeneration[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportType])
  @@index([generatedById])
}

model ReportGeneration {
  id              String   @id @default(uuid())
  savedReportId   String?
  savedReport     SavedReport? @relation(fields: [savedReportId], references: [id])

  reportType      String
  reportName      String
  filters         Json

  // Status
  status          String   @default("COMPLETED") // PENDING | COMPLETED | FAILED

  // Output
  fileUrl         String?
  fileSize        Int?

  // Audit
  generatedById   String
  generatedByName  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([savedReportId])
  @@index([reportType])
  @@index([generatedById])
  @@index([status])
  @@index([createdAt])
}

// ── Lesson Planning System ────────────────────────────────────────────────────

model LessonPlan {
  id              String   @id @default(uuid())
  title           String
  description     String?

  classId         String
  class           Class    @relation(fields: [classId], references: [id])

  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id])

  // Schedule
  plannedDate     DateTime
  duration        Int      @default(60) // minutes
  room            String?

  // Content
  objectives      String[]
  materials       String[]
  activities      String[]
  assessment      String?

  // Status
  status          String   @default("DRAFT") // DRAFT | SCHEDULED | COMPLETED | CANCELLED

  // Audit
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id])

  progress        LessonPlanProgress[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([plannedDate])
  @@index([status])
}

model LessonPlanProgress {
  id              String   @id @default(uuid())
  lessonPlanId    String
  lessonPlan      LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)

  week            Int
  topicsCovered   String[]
  notes           String?
  completed       Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([lessonPlanId, week])
  @@index([lessonPlanId])
  @@index([week])
}

// =============================================================================
// PHASE 2 — ADVANCED EXAM SYSTEM
// =============================================================================

// A logical division of an exam (e.g. "Section 1: Reading"). Sections carry
// their own instructions, optional time limit and optional random subset size.
model ExamSection {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  instructions   String?
  orderIndex     Int      @default(0)
  timeLimitMinutes Int?
  shuffleQuestions Boolean @default(false)
  questionsToPick  Int?    // if set, randomly pick N questions from the section pool

  questions      Question[]
  questionGroups QuestionGroup[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
  @@index([orderIndex])
}

// A shared passage/media resource that one or more questions reference.
model Stimulus {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  type           StimulusType @default(TEXT)
  title          String?
  content        String?  // text / markdown / HTML body
  mediaUrl       String?  // image/audio/video/document URL
  caption        String?
  data           Json?    // structured payload for TABLE / CHART types

  questions      Question[]
  questionGroups QuestionGroup[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
  @@index([type])
}

// Groups questions that share a single stimulus (passage-based question set).
model QuestionGroup {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        ExamSection? @relation(fields: [sectionId], references: [id])
  stimulusId     String?
  stimulus       Stimulus?    @relation(fields: [stimulusId], references: [id])
  title          String?
  instructions   String?
  orderIndex     Int      @default(0)

  questions      Question[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
  @@index([sectionId])
  @@index([stimulusId])
}

// Assigns an exam to a specific student, with optional per-assignment overrides.
model ExamAssignment {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  accommodationId String?
  accommodation  ExamAccommodation? @relation(fields: [accommodationId], references: [id])

  availableFromOverride  DateTime?
  availableUntilOverride DateTime?
  attemptLimitOverride   Int?
  accessCodeOverride     String?
  invigilatorId  String?  // User.id of assigned invigilator (no FK by design)
  status         String   @default("ASSIGNED") // ASSIGNED | STARTED | COMPLETED | INVALIDATED

  attempts       ExamAttempt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([invigilatorId])
}

// Per-student accommodations. examId null = applies to all of the student's exams.
model ExamAccommodation {
  id             String   @id @default(uuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  examId         String?
  exam           Exam?    @relation(fields: [examId], references: [id])

  extraTimePercent Float?
  extraTimeMinutes Int?
  largerText       Boolean @default(false)
  highContrast     Boolean @default(false)
  screenReader     Boolean @default(false)
  reducedDistraction Boolean @default(false)
  calculatorAllowed  Boolean @default(false)
  additionalBreaks   Boolean @default(false)
  separateRoom       Boolean @default(false)
  readerSupport      Boolean @default(false)
  scribeSupport      Boolean @default(false)
  notes              String?

  assignments    ExamAssignment[]
  attempts       ExamAttempt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([studentId])
  @@index([examId])
}

// A reusable rubric attached to an exam or a single question.
model GradingRubric {
  id             String   @id @default(uuid())
  examId         String?
  exam           Exam?    @relation(fields: [examId], references: [id])
  questionId     String?
  question       Question? @relation(fields: [questionId], references: [id])
  title          String
  description    String?
  maxScore       Float    @default(0)

  criteria       RubricCriterion[]
  manualGrades   ManualGrade[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
  @@index([questionId])
}

model RubricCriterion {
  id             String   @id @default(uuid())
  rubricId       String
  rubric         GradingRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  label          String
  description    String?
  maxScore       Float    @default(0)
  orderIndex     Int      @default(0)
  levels         Json?    // optional scoring bands: [{label, points, descriptor}]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([rubricId])
}

// A manual grading record for a single answer requiring human marking.
model ManualGrade {
  id             String   @id @default(uuid())
  attemptId      String
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question @relation(fields: [questionId], references: [id])
  answerId       String?
  answer         ExamAnswer? @relation(fields: [answerId], references: [id])
  rubricId       String?
  rubric         GradingRubric? @relation(fields: [rubricId], references: [id])

  assignedGraderId String?  // User.id the item is queued to
  graderId         String?  // User.id who graded
  criterionScores  Json?    // { rubricCriterionId: score }
  score            Float?
  inlineFeedback   Json?    // [{ anchor, comment }]
  overallComment   String?
  scoreOverride    Float?
  overrideReason   String?
  secondMarkerId   String?
  secondMarkerScore Float?
  moderationComment String?
  status           String   @default("PENDING") // PENDING | IN_REVIEW | GRADED | MODERATED | FINALIZED
  isFinalized      Boolean  @default(false)
  finalizedAt      DateTime?
  finalizedById    String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([attemptId])
  @@index([questionId])
  @@index([answerId])
  @@index([assignedGraderId])
  @@index([status])
}

// Append-only log of significant attempt events (autosave, navigation, pause,
// invigilator actions, integrity signals). Never updated after insert.
model AttemptEvent {
  id             String   @id @default(uuid())
  attemptId      String
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  type           String   // AUTOSAVE | NAVIGATE | PAUSE | RESUME | SUBMIT | AUTO_SUBMIT | DISCONNECT | RECONNECT | FOCUS_LOST | EXTRA_TIME | FORCE_SUBMIT | REOPEN | INVALIDATE | INCIDENT_NOTE | SESSION_TAKEOVER
  actorId        String?  // User.id; null = the student/system
  actorRole      String?
  payload        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([attemptId])
  @@index([type])
  @@index([createdAt])
}

// Immutable snapshots of answer state for crash recovery + audit.
model AttemptSnapshot {
  id             String   @id @default(uuid())
  attemptId      String
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  reason         String   // AUTOSAVE | NAVIGATE | PAUSE | SUBMIT | FINAL
  answers        Json     // frozen copy of all answers at snapshot time
  questionOrder  Json?
  remainingSeconds Int?
  createdAt      DateTime @default(now())

  @@index([attemptId])
  @@index([createdAt])
}

// Controls how and when results become visible to the student.
model ExamResultPolicy {
  id             String   @id @default(uuid())
  examId         String   @unique
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  showScore          Boolean @default(true)
  showPassFail       Boolean @default(true)
  showCorrectAnswers Boolean @default(false)
  showExplanations   Boolean @default(false)
  showTeacherFeedback Boolean @default(true)
  releaseMode    String   @default("IMMEDIATE") // IMMEDIATE | SCHEDULED | AFTER_GRADING | HIDDEN
  releaseAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([examId])
}

// Computed psychometric statistics per question (refreshed on demand).
model QuestionStatistic {
  id             String   @id @default(uuid())
  questionId     String   @unique
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  attempts           Int     @default(0)
  correctCount       Int     @default(0)
  incorrectCount     Int     @default(0)
  blankCount         Int     @default(0)
  avgResponseSeconds Float?
  difficultyIndex    Float?  // p-value (mean proportion correct)
  discriminationIndex Float? // point-biserial / upper-lower
  distractorRates    Json?   // { option: rate }
  avgScore           Float?
  medianScore        Float?
  stdDev             Float?
  passRate           Float?
  scoreDistribution  Json?   // histogram buckets
  flags              String[] @default([]) // TOO_EASY | TOO_HARD | POOR_DISCRIMINATION | UNUSED_DISTRACTOR | SLOW | ABNORMAL_PATTERN

  computedAt     DateTime @default(now())

  @@index([examId])
}
