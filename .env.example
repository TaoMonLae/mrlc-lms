# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/school_lms"

# Secret used to sign auth tokens. MUST be a long, random string (>= 16 chars).
# Generate one with:  openssl rand -base64 48
SESSION_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# Public origin of the app (used for CORS). Set to your real https:// URL in prod.
APP_URL="http://localhost:8000"

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (default 8000).
PORT="8000"

# Where uploaded e-books (EPUB/PDF) are stored on disk. Use a persistent volume.
EBOOK_DIR="./data/ebooks"

# Database backups (pg_dump). Use a persistent volume; keep the last N.
BACKUP_DIR="./data/backups"
BACKUP_RETENTION="14"
# Local hour (0-23) for the daily automatic backup (runs only when enabled in Settings).
BACKUP_HOUR="2"

# Seed credentials. If set, the seed uses these and the account is NOT forced to
# change password. If unset, demo defaults are used and a password change is
# forced on first login. Never rely on demo defaults in production.
# SEED_ADMIN_PASSWORD=""
# SEED_TEACHER_PASSWORD=""
# SEED_STUDENT_PASSWORD=""
