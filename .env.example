# GEMINI_API_KEY: Server-side secret for Gemini AI. Never expose in client bundle.
# Use this only in Express API routes (server-side).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Client-side Gemini key (VITE_ prefix makes it safe for the bundle).
# Only populate this if you intentionally need AI calls from the browser.
# VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins in production.
# Example: https://app.mrlc.edu,https://admin.mrlc.edu
ALLOWED_ORIGINS=""

# PORT: Port the Express server listens on (defaults to 3000).
PORT=3000

# DATABASE_URL: The connection string for your database (e.g., PostgreSQL).
DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# SESSION_SECRET: A random secret string used to sign session cookies.
SESSION_SECRET="CHANGE_ME_TO_A_RANDOM_SECURE_STRING"
